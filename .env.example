# Environment Variables — Employee Admin Dashboard

# ─────────────────────────────────────────────────────────────────────────────
# MICROSOFT ENTRA ID — APP REGISTRATION (Frontend / MSAL)
# These are exposed to the browser (NEXT_PUBLIC_ prefix).
# Safe to expose — they are not secrets.
# ─────────────────────────────────────────────────────────────────────────────

# The Application (client) ID of your Entra ID App Registration
NEXT_PUBLIC_CLIENT_ID=your-client-id-here

# Your Azure AD Tenant ID
NEXT_PUBLIC_TENANT_ID=your-tenant-id-here

# Authority URL — must match your tenant
# Format: https://login.microsoftonline.com/{tenant-id}
NEXT_PUBLIC_AUTHORITY=https://login.microsoftonline.com/your-tenant-id-here


# ─────────────────────────────────────────────────────────────────────────────
# SERVICE PRINCIPAL — SERVER-SIDE SECRETS (never exposed to browser)
# Used by Next.js API routes to call Microsoft Graph with admin permissions.
# ─────────────────────────────────────────────────────────────────────────────

# Client ID of the service principal (can be the same App Registration)
SERVICE_PRINCIPAL_CLIENT_ID=your-client-id-here

# Client Secret — generate this in Entra ID > App Registrations > Certificates & secrets
SERVICE_PRINCIPAL_CLIENT_SECRET=your-client-secret-here


# ─────────────────────────────────────────────────────────────────────────────
# ACCESS CONTROL
# ─────────────────────────────────────────────────────────────────────────────

# Object ID of the security group that is allowed to access the dashboard (HR + IT).
# Find this in Entra ID > Groups > your group > Overview > Object ID.
# If left empty, ALL authenticated users will have access (not recommended for prod).
ALLOWED_SECURITY_GROUP_ID=your-security-group-object-id-here


# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT
# ─────────────────────────────────────────────────────────────────────────────

# For LOCAL development: leave this as-is
# For VERCEL: set this in Vercel > Project > Settings > Environment Variables
#             to your production URL, e.g. https://your-app.vercel.app
# This value is used by MSAL as the redirect URI; it must match what is
# configured in Entra ID > App Registration > Authentication > Redirect URIs.
NEXTAUTH_URL=http://localhost:3000


# ─────────────────────────────────────────────────────────────────────────────
# AZURE TABLE STORAGE — PERSISTENT AUDIT LOG
# ─────────────────────────────────────────────────────────────────────────────

# Connection string for Azure Storage Account used to persist audit/protocol logs.
# Find this in: Azure Portal > Storage Account > Access keys > Connection string.
#
# If left empty, the app falls back to in-memory storage (suitable for local dev,
# but logs will be lost on server restart).
#
# Azure Table Storage setup:
# 1. Create a Storage Account in Azure Portal (same resource group as App Service)
# 2. Copy the connection string from Access keys
# 3. Add it as an environment variable in your App Service > Configuration
AZURE_STORAGE_CONNECTION_STRING=
